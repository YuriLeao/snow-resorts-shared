<?xml version="1.0" encoding="UTF-8"?>
<!--
  Copy to ~/.m2/settings.xml (or merge the <server> entry into your existing file).
  Used both to PUBLISH this repo (write:packages) and to CONSUME the libs from the
  service repos (read:packages).

  Create a GitHub Personal Access Token (classic) with:
    - read:packages   (to download security-lib / contracts in the services)
    - write:packages  (only needed to publish from this repo locally; CI uses GITHUB_TOKEN)
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0">
  <servers>
    <server>
      <id>github</id>
      <username>yurileao</username>
      <password>${env.GITHUB_TOKEN}</password>
    </server>
  </servers>
</settings>
